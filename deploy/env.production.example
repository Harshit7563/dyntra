# Copy to backend/.env on VPS and fill all values

PORT=5001
NODE_ENV=production

# PostgreSQL (docker-compose.prod.yml)
POSTGRES_USER=dyntra
POSTGRES_PASSWORD=CHANGE_TO_STRONG_PASSWORD
POSTGRES_DB=dyntra
DATABASE_URL=postgresql://dyntra:CHANGE_TO_STRONG_PASSWORD@127.0.0.1:5432/dyntra

# Your live domain (no trailing slash)
FRONTEND_URL=https://dyntra.in

JWT_SECRET=CHANGE_TO_LONG_RANDOM_STRING

COMPANY_EMAIL=dynatradex@gmail.com
SMTP_USER=dynatradex@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Dyntra <dynatradex@gmail.com>

PAYMENT_WEBHOOK_SECRET=your-webhook-secret
# BrightPay — if merchant IP is locked (e.g. 82.180.141.135), run deploy/brightpay-proxy.js on that server:
BRIGHTPAY_TOKEN=
BRIGHTPAY_PROXY_URL=http://82.180.141.135:3099
BRIGHTPAY_PROXY_SECRET=change-me-long-random
BRIGHTPAY_API_URL=https://brightpay.co.in/merchant/api/generate_intent
WHATSAPP_BOT_APIKEY=
WHATSAPP_ADMIN_PHONE=919137382475
